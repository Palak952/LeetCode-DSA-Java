
class Solution {
    public List<Integer> inorderTraversal(TreeNode root) {
        List<Integer> res = new ArrayList<>();
        Stack<TreeNode> stack = new Stack<>();
        TreeNode node = root;
        while(!stack.isEmpty() || node!=null){

            //move left
            while(node!=null){
                stack.push(node);
                node=node.left;

            }
            //print the root 
            node = stack.pop();
            res.add(node.val);

            node = node.right;

        }
        return res;
        
    }
}
